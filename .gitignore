# pycache
__pycache__/
*.py[cod]
*$py.class

# installed packages
*.dist-info/
*.egg-info/

# json files
*.json
*.jsonl

# profiling data
*.nsys-rep
*.ncu-rep
*.sqlite

# performance milestone records
!performance_milestones/**/*.json
!performance_milestones/**/*.jsonl
!performance_milestones/**/*.csv
performance_milestones/**/raw/
performance_milestones/**/*.nsys-rep
performance_milestones/**/*.ncu-rep
performance_milestones/**/*.sqlite

# binaries
build/
dist/
*.tar.gz

# virtual environment
.venv/
venv/
env/

# clangd config
.clangd

# .vscode
.vscode/
.coverage
